{
  "name": "server",
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--disable-warning=ExperimentalWarning tsx watch src/index.ts",
    "build": "tsc && cp -r src/db/migrations dist/db/migrations",
    "start": "node --disable-warning=ExperimentalWarning dist/index.js",
    "db:migrate": "NODE_OPTIONS=--disable-warning=ExperimentalWarning tsx src/db/migrate.ts",
    "db:seed": "NODE_OPTIONS=--disable-warning=ExperimentalWarning tsx src/db/seed.ts",
    "test": "NODE_OPTIONS=--disable-warning=ExperimentalWarning vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@hono/zod-validator": "^0.8.0",
    "hono": "^4.12.26",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
